{
  "scripts": [
    {
      "name": "🛠️ Restore Packages",
      "command": "dotnet restore src"
    },
    {
      "name": "🚀 Start Development Server",
      "command": "make dev"
    },
    {
      "name": "🐳 Infrastructure: Start All (SQL Server, Redis)",
      "command": "make infra-up"
    },
    {
      "name": "🐳 Infrastructure: Remove Containers",
      "command": "make infra-down"
    },
    {
      "name": "🗄️ Database: Run Migrations",
      "command": "make db-migrate"
    },
    {
      "name": "🧪 Run Integration Tests",
      "command": "make test"
    },
    {
      "name": "📊 Code Coverage Report",
      "command": "make coverage"
    }
  ]
}
